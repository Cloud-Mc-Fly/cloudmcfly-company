# === Airtable ===
AIRTABLE_PAT=pat...
AIRTABLE_BASE_ID=app...

# === Microsoft Teams / Graph API ===
TEAMS_TENANT_ID=
TEAMS_CLIENT_ID=
TEAMS_CLIENT_SECRET=
TEAMS_WEBHOOK_URL=

# === n8n ===
