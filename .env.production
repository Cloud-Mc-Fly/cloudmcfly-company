# === CloudMcFly Company - Production Environment ===
# Kopiere diese Datei auf den Server als .env und fuelle die Werte aus.

# === App ===
APP_ENV=production
LOG_LEVEL=INFO
# WICHTIG: Aendere diesen Key! Generiere z.B. mit: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=CHANGE_ME_TO_A_SECURE_KEY

# === LLM ===
# Dein Anthropic API Key von https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-DEIN_KEY_HIER
CLAUDE_DEFAULT_MODEL=claude-sonnet-4-6
CLAUDE_COMPLEX_MODEL=claude-opus-4-6
CLAUDE_MAX_TOKENS=4096
CLAUDE_TEMPERATURE=0.7

# === Database ===
# SQLite fuer den Start (laeuft im Docker Volume)
DATABASE_URL=sqlite+aiosqlite:///./data/cloudmcfly.db

# === Airtable (optional, fuer CRM-Sync) ===
AIRTABLE_PAT=
AIRTABLE_BASE_ID=

# === Microsoft 365 / Graph API ===
MS365_TENANT_ID=
MS365_CLIENT_ID=
MS365_CLIENT_SECRET=
MS365_SENDER_EMAIL=contact@cloudmcfly.com
AGENT_NAME=Alexander Ruetz
AGENT_EMAIL=contact@cloudmcfly.com

# === n8n (Phase 4) ===
N8N_WEBHOOK_URL=
N8N_API_KEY=
